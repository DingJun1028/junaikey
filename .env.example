# ========================================
# GCP and Cloud Run Configuration
# ========================================

# Required for Google Cloud Platform
GCP_PROJECT_ID="junaikey"
# Base64-encoded service account JSON (optional for local auth; if omitted, will use current gcloud auth)
GCP_SA_KEY=""
CLOUD_RUN_SERVICE="junaikey-service"
REGION="asia-east1"
ARTIFACT_REPO="junaikey-docker-repo"

# Optional - Set to true to allow unauthenticated access to the Cloud Run service
ALLOW_UNAUTH="true"

# Notes:
# - To fill GCP_SA_KEY: base64 encode the entire JSON: base64 -w0 < key.json (Linux) or base64 -i key.json (macOS)
# - Make sure the service account has roles: Cloud Run Admin, Artifact Registry Admin (or Writer + proper permissions), Cloud Build Editor (if needed).

# ========================================
# Firebase Configuration
# ========================================

# Firebase project configuration
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_API_KEY="your-firebase-api-key"
FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
FIREBASE_DATABASE_URL="https://your-project-default-rtdb.firebaseio.com/"
FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="123456789012"
FIREBASE_APP_ID="1:123456789012:web:abcdef123456"

# Firebase Admin SDK credentials path (for local development)
GOOGLE_APPLICATION_CREDENTIALS="/path/to/your/gcp-service-account-key.json"

# Firebase service account key for GitHub Actions (base64 encoded)
FIREBASE_SERVICE_ACCOUNT=""

# ========================================
# AI Model Configuration
# ========================================

# Required for TensorZero to access OpenAI models
OPENAI_API_KEY="sk-..."

# Google AI (Gemini) API configuration
GOOGLE_AI_API_KEY="your-google-ai-api-key"
GEMINI_API_KEY="your-gemini-api-key"

# Other AI model providers (optional)
ANTHROPIC_API_KEY="your-anthropic-api-key"
COHERE_API_KEY="your-cohere-api-key"

# ========================================
# Database Configuration
# ========================================

# ClickHouse configuration for TensorZero observability and data logging
# For local development, you can run ClickHouse in Docker.
TENSORZERO_CLICKHOUSE_URL="http://chuser:chpassword@localhost:8123/tensorzero"
CLICKHOUSE_USER="chuser"
CLICKHOUSE_PASSWORD="chpassword"
CLICKHOUSE_DATABASE="tensorzero"

# Additional database URLs (if using multiple databases)
DATABASE_URL="postgresql://user:password@localhost:5432/junaikey"
REDIS_URL="redis://localhost:6379"

# ========================================
# Python API Configuration
# ========================================

# Python API server configuration
API_HOST="0.0.0.0"
API_PORT="8080"
API_WORKERS="1"

# Python environment settings
PYTHONDONTWRITEBYTECODE="1"
PYTHONUNBUFFERED="1"

# ========================================
# Node.js Application Configuration
# ========================================

# Next.js configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"
NODE_ENV="development"
PORT="3000"

# ========================================
# Security and Authentication
# ========================================

# JWT configuration
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="7d"

# API keys for external services
EXTERNAL_API_KEY="your-external-api-key"

# ========================================
# Monitoring and Observability
# ========================================

# OpenTelemetry configuration
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
OTEL_SERVICE_NAME="JunAiKey_Omnikey_萬能系統_終焉奇點"

# Logging configuration
LOG_LEVEL="info"
REQUEST_ID_HEADER="X-Request-Id"

# ========================================
# Development and Testing
# ========================================

# Development mode flags
DEBUG="false"
VERBOSE_LOGGING="false"

# Testing configuration
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/junaikey_test"
MOCK_EXTERNAL_SERVICES="false"