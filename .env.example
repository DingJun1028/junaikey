# Required
GCP_PROJECT_ID="junaikey"
# Base64-encoded service account JSON (optional for local auth; if omitted, will use current gcloud auth)
GCP_SA_KEY=""
CLOUD_RUN_SERVICE="junaikey-service"
REGION="asia-east1"
ARTIFACT_REPO="junaikey-docker-repo"

# Optional
# Set to true to allow unauthenticated access to the Cloud Run service. Otherwise the script will deploy with --no-allow-unauthenticated.
ALLOW_UNAUTH="true"

# Notes:
# - To fill GCP_SA_KEY: base64 encode the entire JSON: base64 -w0 < key.json (Linux) or base64 -i key.json (macOS)
# - Make sure the service account has roles: Cloud Run Admin, Artifact Registry Admin (or Writer + proper permissions), Cloud Build Editor (if needed).

# -------------------------------------------
# Application Specific Environment Variables
# -------------------------------------------

# Required for TensorZero to access OpenAI models
OPENAI_API_KEY="sk-..."

# Required for TensorZero observability and data logging.
# For local development, you can run ClickHouse in Docker.
# See TensorZero QuickStart guide for a docker-compose example.
TENSORZERO_CLICKHOUSE_URL="http://chuser:chpassword@localhost:8123/tensorzero"

# Required for Firebase Admin SDK to authenticate with Google Cloud services for local development.
# On Cloud Run, this is not needed as the SDK uses the runtime's service account automatically.
GOOGLE_APPLICATION_CREDENTIALS="/path/to/your/gcp-service-account-key.json"