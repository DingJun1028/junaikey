rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow authenticated users to read/write blueprints
    match /blueprints/{blueprintId} {
      allow read, write: if request.auth != null;
    }

    // Allow only server-side (via cloud functions) to create event cards
    // Clients can read them if authenticated
    match /eventCards/{cardId} {
      allow read: if request.auth != null;
      allow create: if false; // To be written by backend only
      allow update, delete: if false;
    }
  }
}
