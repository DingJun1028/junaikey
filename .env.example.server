# Backend / CI Secrets (DO NOT COMMIT REAL VALUES)
# Core
NODE_ENV=production
LOG_LEVEL=info
SACRED_API_KEY=sk_sacred_<generate_64_hex>
SACRED_HMAC_REQUIRED=true
SACRED_ALLOWED_DRIFT=300

# Supabase (High Privilege)
SUPABASE_SERVICE_ROLE_KEY=sb_sr_<never_expose>
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=<rotate_strong_pw>
SUPABASE_DB_NAME=postgres

# Providers
OPENAI_API_KEY=sk-openai-...
GEMINI_API_KEY=AIza...<gemini_key>...
STRAICO_API_KEY=str_...
CAPACITIES_API_KEY=cap_...
BOOST_API_KEY=bst_...
NOTION_API_KEY=secret_...
AITABLE_API_KEY=atk_...
MYMEMOAI_API_KEY=mm_...
TASKADE_API_KEY=td_...

# GitHub / OAuth
GITHUB_TOKEN=<if_needed_fine_grained_pat>
OAUTH_CLIENT_ID=1080502198465-xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=GOCSPX-<rotated_secret>

# Firebase Admin (Choose ONE of the two approaches)
FIREBASE_PROJECT_ID=junaikey-genesis
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xyz@junaikey-genesis.iam.gserviceaccount.com
# Escaped multiline form
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<escaped_lines>\n-----END PRIVATE KEY-----\n"
# OR base64 form (leave above empty if using this)
# FIREBASE_PRIVATE_KEY_B64=<base64_block>

# Feature Flags
ENABLE_CODE_ANALYSIS=true
ENABLE_TAG_AUTOGEN=true

# CORS / Security
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com