# Straico Cost Governance Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# STRAICO API CONFIGURATION
# =============================================================================

# Your Straico API key (required)
STRAICO_API_KEY=your_api_key_here

# Default pricing mode: per_word or per_message
# per_word: Better for short interactions, charges by token count
# per_message: Fixed rate per request, better for long content
STRAICO_DEFAULT_MODE=per_word

# Default AI model to use
STRAICO_MODEL=gpt-4-turbo

# API endpoint (if different from default)
STRAICO_BASE_URL=https://api.straico.com/v1

# Request timeout in seconds
STRAICO_TIMEOUT=120

# =============================================================================
# COST GOVERNANCE SETTINGS
# =============================================================================

# Budget limits (in USD)
STRAICO_DAILY_BUDGET=100.00
STRAICO_MONTHLY_BUDGET=2000.00
STRAICO_YEARLY_BUDGET=20000.00

# Warning thresholds (as decimal: 0.8 = 80%)
STRAICO_WARN_THRESHOLD=0.8
STRAICO_HARD_LIMIT=1.0

# Per-request cost limits
STRAICO_MAX_COST_PER_REQUEST=10.00
STRAICO_MAX_WORDS_PER_REQUEST=10000

# =============================================================================
# PRICING MODE SWITCHING LOGIC
# =============================================================================

# Word count threshold for automatic mode switching
# Below this count: use per_word mode
# Above this count: use per_message mode
STRAICO_WORD_THRESHOLD=1000

# Cost comparison factor (decimal)
# If per_message_cost < per_word_cost * factor, use per_message
STRAICO_MODE_SWITCH_FACTOR=0.9

# =============================================================================
# FALLBACK CONFIGURATION
# =============================================================================

# Enable automatic fallbacks when cost limits are approached
STRAICO_ENABLE_FALLBACKS=true

# Fallback model (cheaper alternative)
STRAICO_FALLBACK_MODEL=gpt-3.5-turbo

# Enable RAG (Retrieval Augmented Generation) for cost reduction
STRAICO_ENABLE_RAG=true
STRAICO_RAG_CHUNK_SIZE=1000
STRAICO_RAG_MAX_CHUNKS=5

# Enable response caching
STRAICO_ENABLE_CACHING=true
STRAICO_CACHE_TTL=3600  # seconds
STRAICO_CACHE_MAX_SIZE=1000  # number of cached responses

# Enable request queuing when approaching limits
STRAICO_ENABLE_QUEUING=true
STRAICO_QUEUE_MAX_SIZE=100
STRAICO_QUEUE_PRIORITY=fifo  # fifo, lifo, priority

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================

# Enable detailed cost logging
STRAICO_ENABLE_COST_LOGGING=true
STRAICO_LOG_LEVEL=INFO

# Cost tracking database (optional)
STRAICO_COST_DB_URL=postgresql://user:pass@localhost/straico_costs

# Webhook URL for cost alerts (optional)
STRAICO_WEBHOOK_URL=https://your-webhook-endpoint.com/straico-alerts

# Slack/Discord notifications (optional)
STRAICO_SLACK_WEBHOOK_URL=
STRAICO_DISCORD_WEBHOOK_URL=

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================

# Retry configuration
STRAICO_MAX_RETRIES=3
STRAICO_RETRY_DELAY=1  # seconds
STRAICO_BACKOFF_FACTOR=2.0

# Rate limiting
STRAICO_RATE_LIMIT_PER_MINUTE=60
STRAICO_RATE_LIMIT_PER_HOUR=1000
STRAICO_RATE_LIMIT_PER_DAY=10000

# Prompt optimization
STRAICO_ENABLE_PROMPT_OPTIMIZATION=true
STRAICO_MAX_PROMPT_LENGTH=4000

# Token estimation (for cost calculation before API calls)
STRAICO_ESTIMATE_TOKENS=true
STRAICO_TOKEN_BUFFER_FACTOR=1.1  # 10% buffer for estimation errors

# =============================================================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# =============================================================================

# Development environment (no cost limits)
# STRAICO_DEV_MODE=true

# Testing environment (reduced limits)
# STRAICO_TEST_DAILY_BUDGET=10.00
# STRAICO_TEST_MAX_COST_PER_REQUEST=1.00

# Production environment (strict limits)
# STRAICO_PROD_DAILY_BUDGET=500.00
# STRAICO_PROD_MONTHLY_BUDGET=10000.00